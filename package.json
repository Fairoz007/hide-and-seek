{
  "name": "chroma-hunt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"vite\" \"tsx watch server/index.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node dist-server/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "three": "^0.169.0",
    "@dimforge/rapier3d-compat": "^0.14.0",
    "gsap": "^3.12.5",
    "howler": "^2.2.4",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0",
    "express": "^4.21.0",
    "nanoid": "^5.0.7"
  },
  "devDependencies": {
    "vite": "^5.4.8",
    "typescript": "5.7.3",
    "tsx": "^4.19.1",
    "concurrently": "^9.0.1",
    "@types/three": "^0.169.0",
    "@types/howler": "^2.2.11",
    "@types/express": "^4.17.21",
    "@types/node": "^24.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
